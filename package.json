{
  "name": "glimpseui",
  "version": "0.3.7",
  "description": "Native macOS micro-UI for scripts and agents — sub-50ms WKWebView windows with bidirectional JSON communication",
  "type": "module",
  "main": "src/glimpse.mjs",
  "exports": {
    ".": "./src/glimpse.mjs"
  },
  "bin": {
    "glimpseui": "bin/glimpse.mjs"
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "build:macos": "node scripts/build.mjs darwin",
    "build:linux": "node scripts/build.mjs linux",
    "postinstall": "node scripts/postinstall.mjs",
    "test": "node test/test.mjs",
    "publish:check": "./scripts/publish.sh --dry-run",
    "publish:npm": "./scripts/publish.sh"
  },
  "files": [
    "src/glimpse.swift",
    "src/glimpse.mjs",
    "src/follow-cursor-support.mjs",
    "src/linux/",
    "bin/glimpse.mjs",
    "scripts/build.mjs",
    "scripts/postinstall.mjs",
    "pi-extension/index.ts",
    "pi-extension/companion.mjs",
    "skills/glimpse/SKILL.md",
    "README.md",
    "CHANGELOG.md"
  ],
  "pi": {
    "extensions": [
      "./pi-extension/index.ts"
    ],
    "skills": [
      "./skills"
    ]
  },
  "engines": {
    "node": ">=18"
  },
  "os": [
    "darwin",
    "linux"
  ],
  "keywords": [
    "macos",
    "webview",
    "native",
    "ui",
    "webkit",
    "wkwebview",
    "swift",
    "gui",
    "agent",
    "dialog",
    "prompt",
    "overlay",
    "pi-package"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/hazat/glimpse"
  },
  "author": "hazat",
  "license": "MIT"
}
